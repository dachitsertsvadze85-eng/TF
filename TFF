<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TF Cars - Premium Car Brands</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #000000;
            font-family: 'Arial', sans-serif;
            color: #00ff00;
        }

        /* Header Styling */
        header {
            background-color: #000000;
            border-bottom: 2px solid #00ff00;
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Categories on Top Left */
        .categories {
            display: flex;
            gap: 20px;
            flex: 1;
        }

        .categories a {
            color: #00ff00;
            text-decoration: none;
            font-size: 16px;
            font-weight: bold;
            transition: all 0.3s ease;
            border: 1px solid transparent;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
        }

        .categories a:hover {
            border: 1px solid #00ff00;
            background-color: rgba(0, 255, 0, 0.1);
        }

        /* Title in Center */
        .logo-title {
            flex: 1;
            text-align: center;
            font-size: 32px;
            font-weight: bold;
            color: #00ff00;
            letter-spacing: 3px;
        }

        /* Search Bar on Top Right */
        .search-container {
            flex: 1;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }

        .search-container input {
            padding: 10px 15px;
            width: 200px;
            background-color: #1a1a1a;
            border: 1px solid #00ff00;
            color: #00ff00;
            border-radius: 5px;
            font-size: 14px;
        }

        .search-container input::placeholder {
            color: #00aa00;
        }

        .search-container input:focus {
            outline: none;
            box-shadow: 0 0 10px #00ff00;
        }

        .search-btn {
            padding: 10px 20px;
            background-color: #00ff00;
            color: #000000;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .search-btn:hover {
            background-color: #00aa00;
            transform: scale(1.05);
        }

        /* Main Content */
        main {
            padding: 40px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: calc(100vh - 100px);
        }

        /* Car Brands Container */
        .brands-container {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 30px;
            width: 100%;
            max-width: 1200px;
        }

        /* Brand Card Styling */
        .brand-card {
            background-color: #1a1a1a;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 300px;
            transition: all 0.3s ease;
            cursor: pointer;
            overflow: hidden;
        }

        .brand-card:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px #00ff00;
            background-color: rgba(0, 255, 0, 0.05);
        }

        .brand-card img {
            width: 100%;
            height: 85%;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 10px;
        }

        .brand-name {
            color: #00ff00;
            font-size: 18px;
            font-weight: bold;
            text-align: center;
        }

        .hidden {
            display: none;
        }

        .no-results {
            grid-column: 1 / -1;
            text-align: center;
            font-size: 20px;
            color: #00ff00;
            padding: 40px;
        }

        /* Responsive Design */
        @media (max-width: 1024px) {
            .brands-container {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            header {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }

            .categories {
                justify-content: center;
            }

            .search-container {
                justify-content: center;
            }

            .search-container input {
                width: 150px;
            }

            .brands-container {
                grid-template-columns: repeat(1, 1fr);
                gap: 20px;
            }

            .brand-card {
                height: 250px;
            }
        }
    </style>
</head>
<body>
    <!-- Header Section -->
    <header>
        <!-- Categories on Left -->
        <div class="categories">
            <a href="#" onclick="filterByCategory('all')">All Cars</a>
            <a href="#" onclick="filterByCategory('luxury')">Luxury</a>
            <a href="#" onclick="filterByCategory('sports')">Sports</a>
        </div>

        <!-- Website Title in Center -->
        <div class="logo-title">TF CARS</div>

        <!-- Search Bar on Right -->
        <div class="search-container">
            <input type="text" id="searchInput" placeholder="Search cars..." onkeyup="searchCars()">
            <button class="search-btn" onclick="searchCars()">Search</button>
        </div>
    </header>

    <!-- Main Content -->
    <main>
        <div class="brands-container" id="brandsContainer">
            <!-- Toyota Card -->
            <div class="brand-card" data-brand="toyota" data-category="luxury">
                <img src="data:image/jpeg;base64," alt="Toyota" style="height: 100%; object-fit: contain;">
                <div class="brand-name">Toyota</div>
            </div>

            <!-- BMW Card -->
            <div class="brand-card" data-brand="bmw" data-category="luxury sports">
                <img src="data:image/jpeg;base64," alt="BMW" style="height: 100%; object-fit: contain;">
                <div class="brand-name">BMW</div>
            </div>

            <!-- Mercedes Card -->
            <div class="brand-card" data-brand="mercedes" data-category="luxury sports">
                <img src="data:image/jpeg;base64," alt="Mercedes" style="height: 100%; object-fit: contain;">
                <div class="brand-name">Mercedes</div>
            </div>

            <!-- Audi Card -->
            <div class="brand-card" data-brand="audi" data-category="luxury sports">
                <img src="data:image/jpeg;base64," alt="Audi" style="height: 100%; object-fit: contain;">
                <div class="brand-name">Audi</div>
            </div>
        </div>
    </main>

    <script>
        // Search Function
        function searchCars() {
            const searchInput = document.getElementById('searchInput').value.toLowerCase();
            const brandCards = document.querySelectorAll('.brand-card');
            let visibleCount = 0;

            brandCards.forEach(card => {
                const brandName = card.getAttribute('data-brand').toLowerCase();
                const cardText = card.textContent.toLowerCase();

                if (brandName.includes(searchInput) || cardText.includes(searchInput)) {
                    card.classList.remove('hidden');
                    visibleCount++;
                } else {
                    card.classList.add('hidden');
                }
            });

            // Show "No results" message
            let noResultsMsg = document.getElementById('noResults');
            if (visibleCount === 0 && searchInput.length > 0) {
                if (!noResultsMsg) {
                    noResultsMsg = document.createElement('div');
                    noResultsMsg.id = 'noResults';
                    noResultsMsg.className = 'no-results';
                    document.getElementById('brandsContainer').appendChild(noResultsMsg);
                }
                noResultsMsg.textContent = `No cars found matching "${searchInput}"`;
                noResultsMsg.classList.remove('hidden');
            } else if (noResultsMsg) {
                noResultsMsg.classList.add('hidden');
            }
        }

        // Filter by Category Function
        function filterByCategory(category) {
            const brandCards = document.querySelectorAll('.brand-card');
            document.getElementById('searchInput').value = '';
            let visibleCount = 0;

            brandCards.forEach(card => {
                const cardCategory = card.getAttribute('data-category');

                if (category === 'all') {
                    card.classList.remove('hidden');
                    visibleCount++;
                } else if (cardCategory.includes(category)) {
                    card.classList.remove('hidden');
                    visibleCount++;
                } else {
                    card.classList.add('hidden');
                }
            });

            // Show "No results" message
            let noResultsMsg = document.getElementById('noResults');
            if (visibleCount === 0) {
                if (!noResultsMsg) {
                    noResultsMsg = document.createElement('div');
                    noResultsMsg.id = 'noResults';
                    noResultsMsg.className = 'no-results';
                    document.getElementById('brandsContainer').appendChild(noResultsMsg);
                }
                noResultsMsg.textContent = `No cars found in this category`;
                noResultsMsg.classList.remove('hidden');
            } else if (noResultsMsg) {
                noResultsMsg.classList.add('hidden');
            }
        }
    </script>
</body>
</html>
